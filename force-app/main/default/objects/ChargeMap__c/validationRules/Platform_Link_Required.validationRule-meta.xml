<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Platform_Link_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL( InvoiceSendingMethod__c , &quot;Platform&quot;),
    ISBLANK(PlatformLink__c)
)</errorConditionFormula>
    <errorDisplayField>PlatformLink__c</errorDisplayField>
    <errorMessage>Please provide the platform link.</errorMessage>
</ValidationRule>
