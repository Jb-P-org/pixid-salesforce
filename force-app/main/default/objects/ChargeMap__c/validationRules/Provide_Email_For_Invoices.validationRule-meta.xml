<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Provide_Email_For_Invoices</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL( InvoiceSendingMethod__c , &quot;Email&quot;),
    ISBLANK(SendInvoiceTo__c)
)</errorConditionFormula>
    <errorDisplayField>SendInvoiceTo__c</errorDisplayField>
    <errorMessage>Please provide the billing email.</errorMessage>
</ValidationRule>
